{
  "mcpServers": {
    "attocode-code-intel": {
      "command": "uv",
      "args": [
        "run",
        "attocode-code-intel",
        "--project",
        "${workspaceFolder}",
        "--local-only"
      ],
      "type": "stdio",
      "env": {
        "PATH": "/opt/homebrew/bin:/usr/local/bin:${env:PATH}"
      }
    }
  }
}
